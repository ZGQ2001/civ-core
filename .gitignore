# ==========================================
# 1. 虚拟环境和 Python 版本管理（隔离依赖，避免冲突）
# ==========================================
.venv/
/.python-version

# ==========================================
# 2. Python 编译产物（清理构建文件，保持仓库整洁）
# ==========================================
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================================
# 3. 业务数据解耦（大型二进制文件与原始数据）
# ==========================================
01_Input/
03_Output/
*.pdf
*.jpg
*.jpeg
*.png
*.xlsx
*.docx

# ==========================================
# 4. 本地配置（排除 IDE 干扰，保护关键配置）
# ==========================================
.vscode/
.claude/
*.egg-info/
.eggs/
.pytest_cache/
# .idea/  # 如果使用 JetBrains 系列 IDE，可以取消注释
!handwrite_config.json
!pyproject.toml
