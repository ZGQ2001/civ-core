# ==========================================
# 1. 虚拟环境和 Python 版本管理（隔离依赖，避免冲突）
# ==========================================
.venv/
/.python-version

# ==========================================
# 2. Python 编译产物（清理构建文件，保持仓库整洁）
# ==========================================
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================================
# 3. 业务数据解耦（大型二进制文件与原始数据）
# ==========================================
*.pdf
*.jpg
*.jpeg
*.png
*.svg
*.xlsx
*.docx
*.pptx
!frontend/src-tauri/icons/
!frontend/src-tauri/icons/*.png
!frontend/src-tauri/icons/*.ico
!frontend/src-tauri/icons/*.icns
data/training_materials/
# ==========================================
# 4. 本地配置（排除 IDE 干扰，保护关键配置）
# ==========================================
*.log
*.jsonl
.vscode/
.claude/
!.claude/skills/
!.claude/skills/**
.deepseek/
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
# .idea/  # 如果使用 JetBrains 系列 IDE，可以取消注释
!handwrite_config.json
!pyproject.toml

# ==========================================
# 5. 前端（Vite + React + Tauri）
# ==========================================
node_modules/
frontend/dist/
frontend/.vite/
# Tauri 构建产物（T3 之后会出现）
frontend/src-tauri/target/
# 注：Cargo.lock 对应用项目应该提交（锁依赖版本，保证可重现 build），不 ignore
# Python sidecar 打包产物（T6 之后会出现）
build/
dist/
*.spec

# ==========================================
# 6. C# sidecar（dotnet/civ-doc/，T5.5 之后）
# ==========================================
dotnet/**/bin/
dotnet/**/obj/
*.user

