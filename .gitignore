# ==========================================
# 1. 虚拟环境和 Python 版本管理（隔离依赖，避免冲突）
# ==========================================
.venv/
/.python-version

# ==========================================
# 2. Python 编译产物（清理构建文件，保持仓库整洁）
# ==========================================
**/__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================================
# 3. 业务数据解耦（大型二进制文件与原始数据）
# ==========================================
*.pdf
*.jpg
*.jpeg
*.png
*.xlsx
*.docx
*.pptx
data/training_materials/
# ==========================================
# 4. 本地配置（排除 IDE 干扰，保护关键配置）
# ==========================================
*.log
*.jsonl
.vscode/
.claude/
.deepseek/
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
# .idea/  # 如果使用 JetBrains 系列 IDE，可以取消注释
!handwrite_config.json
!pyproject.toml

# ==========================================
# 5. 前端（Vite + React + Tauri）
# ==========================================
node_modules/
frontend/dist/
frontend/.vite/
# Tauri 构建产物（T3 之后会出现）
src-tauri/target/
src-tauri/Cargo.lock
# Python sidecar 打包产物（T6 之后会出现）
build/
dist/
*.spec
