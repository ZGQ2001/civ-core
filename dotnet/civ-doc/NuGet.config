<?xml version="1.0" encoding="utf-8"?>
<!--
  项目级 NuGet 源配置：走中国镜像（华为云 NuGet v3），fallback 到官方源。
  CLAUDE.md「中国镜像」表已统一规约。
  华为云镜像主要给国内开发者用；如果用户在国外可以删 huawei 项让 nuget.org 直连。
-->
<configuration>
  <packageSources>
    <clear />
    <add key="huawei" value="https://mirrors.huaweicloud.com/repository/nuget/v3/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
